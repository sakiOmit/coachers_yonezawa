{
  "name": "{{PROJECT_NAME}}",
  "version": "1.0.0",
  "description": "WordPressテーマ",
  "private": true,
  "type": "module",
  "scripts": {
    "init": "node scripts/init-project.js",
    "create-template": "node scripts/create-template.js",
    "dev": "vite",
    "clean:build": "node scripts/build/clean.js",
    "build": "npm run clean:build && vite build",
    "preview": "vite preview",
    "setup:vite-dev": "bash scripts/setup-vite-dev.sh",
    "docker:init": "docker compose up -d && bash scripts/docker-post-start.sh",
    "docker:setup": "bash scripts/docker-post-start.sh",
    "theme:rename": "tsx scripts/rename-theme.ts",
    "clean:themes": "bash scripts/clean-default-themes.sh",
    "image-opt": "tsx scripts/optimize/images.ts",
    "image-retina": "node scripts/generate-retina-images.js",
    "wp:init": "npm run wp:create-templates && npm run wp:setup",
    "wp:setup": "tsx scripts/wordpress/setup-pages.ts",
    "wp:create-templates": "tsx scripts/wordpress/create-templates.ts",
    "check:links": "tsx scripts/check/links-static.ts",
    "check:links:crawl": "tsx scripts/check/links-crawl.ts",
    "check:images": "tsx scripts/check/images-404.ts",
    "check:html": "node scripts/check/html-validate.js",
    "check:html:semantic": "tsx scripts/check/html-semantic.ts",
    "check:templates": "tsx scripts/check/templates-quality.ts",
    "check:alt": "tsx scripts/check/alt-attribute.ts",
    "check:unused-functions": "node scripts/check-unused-functions.js",
    "detect:unused": "node scripts/detect-unused-code.js",
    "detect:comments": "node scripts/detect-redundant-comments.js",
    "detect:all": "node scripts/detect-unused-code.js && node scripts/detect-redundant-comments.js",
    "detect:all:json": "node scripts/detect-unused-code.js --json && node scripts/detect-redundant-comments.js --json",
    "check:astro": "tsx scripts/check/astro-html-check.ts",
    "check:all": "tsx scripts/check/run-all.ts",
    "qa:check": "tsx scripts/qa/check.ts",
    "qa:fix": "npm run lint:fix",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:js": "eslint 'src/**/*.{js,ts}'",
    "lint:css": "stylelint 'src/scss/**/*.scss' && node scripts/check-bem-nesting.js",
    "lint:php": "./vendor/bin/phpcs",
    "lint:css:fix": "stylelint 'src/scss/**/*.scss' --fix",
    "lint:php:fix": "./vendor/bin/phpcbf",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css:fix && npm run lint:php:fix",
    "format": "prettier --write 'src/**/*.{js,ts,css,scss,json,md}'",
    "astro:install": "cd astro && npm install",
    "astro:dev": "cd astro && npm run dev",
    "astro:build": "cd astro && npm run build",
    "astro:preview": "cd astro && npm run preview"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@playwright/test": "^1.56.1",
    "@splidejs/splide": "^4.1.4",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.16",
    "critters": "^0.0.23",
    "cssnano": "^7.1.2",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "glob": "^11.0.0",
    "gsap": "^3.14.1",
    "html-validate": "^10.4.0",
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^11.0.1",
    "imagemin-webp": "^8.0.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.32",
    "postcss-html": "^1.6.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.2.5",
    "sass": "^1.70.0",
    "sharp": "^0.33.2",
    "stylelint": "^16.25.0",
    "stylelint-config-recess-order": "^5.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-prettier": "^5.0.0",
    "stylelint-scss": "^6.12.1",
    "svgo": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vite": "^7.3.0",
    "vite-plugin-live-reload": "^3.0.5"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ],
  "dependencies": {
    "@splidejs/splide-extension-auto-scroll": "^0.5.3",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "simplebar": "^6.3.3"
  }
}
