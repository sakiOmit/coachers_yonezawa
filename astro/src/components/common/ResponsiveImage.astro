---
/**
 * ResponsiveImage
 * WebP専用・Retina対応・レスポンシブ画像コンポーネント
 *
 * WordPress変換先: render_responsive_image() (inc/image-helpers.php)
 *
 * 出力パターン:
 *   - SVG: <img> のみ (width/height自動付与)
 *   - SP分岐あり: <picture> + <source>(1x,2x,3x) + <img>(1x,2x)
 *   - SP分岐なし: <img srcset="1x, 2x"> のみ
 *
 * CSS: 画像要素は base スタイル (max-width: 100%; height: auto;) を継承
 */
import { existsSync, readFileSync } from 'node:fs';
import { resolve, extname } from 'node:path';

interface Props {
  /** 画像パス（例: "/assets/images/hero.webp"） */
  src: string;
  /** alt属性 */
  alt?: string;
  /** CSSクラス（img要素に適用） */
  class?: string;
  /** picture要素のクラス */
  wrapperClass?: string;
  /** SP画像を使用するか（デフォルト: true） */
  sp?: boolean;
  /** loading属性（デフォルト: "lazy"） */
  loading?: 'lazy' | 'eager';
  /** width属性（指定で上書き） */
  width?: number;
  /** height属性（指定で上書き） */
  height?: number;
  /** SP/PC切り替えブレークポイント（デフォルト: 767） */
  breakpoint?: number;
}

const {
  src,
  alt = '',
  class: className,
  wrapperClass,
  sp = true,
  loading = 'lazy',
  width: propWidth,
  height: propHeight,
  breakpoint = 767,
} = Astro.props;

// --- パス解析 ---
const ext = extname(src).toLowerCase();
const isSvg = ext === '.svg';
const basePath = src.replace(/\.[^.]+$/, '');

// PC WebP パス
const pcWebp = isSvg ? null : `${basePath}.webp`;
const pcWebp2x = isSvg ? null : `${basePath}@2x.webp`;

// SP WebP パス
const hasSp = sp && !isSvg;
const spWebp = hasSp ? `${basePath}_sp.webp` : null;
const spWebp2x = hasSp ? `${basePath}_sp@2x.webp` : null;
const spWebp3x = hasSp ? `${basePath}_sp@3x.webp` : null;

// --- width/height 自動取得 ---
let imgWidth: number | undefined = propWidth ?? undefined;
let imgHeight: number | undefined = propHeight ?? undefined;

if (imgWidth === undefined || imgHeight === undefined) {
  try {
    const publicDir = resolve(process.cwd(), 'public');
    const filePath = resolve(publicDir, src.replace(/^\//, ''));

    if (existsSync(filePath)) {
      if (isSvg) {
        // SVG: viewBox から取得
        const svgContent = readFileSync(filePath, 'utf-8');
        const viewBoxMatch = svgContent.match(/viewBox=["']([^"']+)["']/);
        if (viewBoxMatch) {
          const parts = viewBoxMatch[1].split(/\s+/).map(Number);
          if (parts.length === 4) {
            imgWidth = imgWidth ?? Math.round(parts[2]);
            imgHeight = imgHeight ?? Math.round(parts[3]);
          }
        }
        // width/height属性フォールバック
        if (imgWidth === undefined) {
          const wMatch = svgContent.match(/\bwidth=["'](\d+(?:\.\d+)?)(?:px)?["']/);
          if (wMatch) imgWidth = Math.round(parseFloat(wMatch[1]));
        }
        if (imgHeight === undefined) {
          const hMatch = svgContent.match(/\bheight=["'](\d+(?:\.\d+)?)(?:px)?["']/);
          if (hMatch) imgHeight = Math.round(parseFloat(hMatch[1]));
        }
      } else {
        // WebP/PNG/JPG: image-size パッケージで取得
        try {
          const { default: sizeOf } = await import('image-size');
          const dimensions = sizeOf(filePath);
          if (dimensions?.width && dimensions?.height) {
            const isRetina = src.includes('@2x');
            const divisor = isRetina ? 2 : 1;
            imgWidth = imgWidth ?? Math.round(dimensions.width / divisor);
            imgHeight = imgHeight ?? Math.round(dimensions.height / divisor);
          }
        } catch {
          // image-size が未インストールの場合はスキップ
        }
      }
    }
  } catch {
    // ファイルアクセスエラーは無視
  }
}
---

{isSvg ? (
  <img
    src={src}
    width={imgWidth}
    height={imgHeight}
    alt={alt}
    loading={loading}
    class={className}
  />
) : hasSp ? (
  <picture class={wrapperClass}>
    <source
      media={`(max-width: ${breakpoint}px)`}
      srcset={`${spWebp} 1x, ${spWebp2x} 2x, ${spWebp3x} 3x`}
    />
    <img
      src={pcWebp}
      srcset={`${pcWebp} 1x, ${pcWebp2x} 2x`}
      width={imgWidth}
      height={imgHeight}
      alt={alt}
      loading={loading}
      class={className}
    />
  </picture>
) : (
  <img
    src={pcWebp}
    srcset={`${pcWebp} 1x, ${pcWebp2x} 2x`}
    width={imgWidth}
    height={imgHeight}
    alt={alt}
    loading={loading}
    class={className}
  />
)}
