# WordPress + Vite + FLOCSS Project .gitignore

# Dependencies
node_modules/
vendor/

# Build output
themes/*/assets/css/
themes/*/assets/js/
dist/

# Vite
*.local
.vite/

# Environment files
# .env is tracked for local development defaults
.env.local
.env.*.local
.env.development.local
.env.production.local

# IDE / Editor
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker (local data)
docker-data/
mysql-data/

# WordPress uploads (optional - uncomment if needed)
# themes/*/uploads/
# wp-content/uploads/

# Cache
.cache/
*.cache

# Temporary files
tmp/
temp/

# Claude Code (project-specific)
.claude/reviews/
.claude/checkpoints/
.init-done

# Figma cache (shared across team)
.claude/cache/*
!.claude/cache/figma/

# Serena temporary files (keep memories)
.serena/project.yml
.serena/*.log

# Test output
coverage/
test-results/
playwright-report/

# Docker WordPress data (local only)
wordpress_data/

# Playwright MCP screenshots
.playwright-mcp/

themes/*/assets/*
!themes/*/assets/images/
themes/*/assets/images/*
!themes/*/assets/images/favicon.ico
!themes/*/assets/images/apple-touch-icon.png
!themes/*/assets/images/android-chrome-192x192.png
!themes/*/assets/images/site.webmanifest
themes/twenty*
themes/test-theme

# Astro
astro/node_modules/
astro/dist/
astro/.astro/
