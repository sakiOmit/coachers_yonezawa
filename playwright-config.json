{
  "use": {
    "headless": true,
    "viewport": {
      "width": 1440,
      "height": 900
    },
    "locale": "ja-JP",
    "timezoneId": "Asia/Tokyo",
    "screenshot": "only-on-failure",
    "video": "retain-on-failure",
    "trace": "retain-on-failure",
    "launchOptions": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    }
  },
  "projects": [
    {
      "name": "chromium-desktop",
      "use": {
        "browserName": "chromium",
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "deviceScaleFactor": 2
      }
    },
    {
      "name": "chromium-mobile",
      "use": {
        "browserName": "chromium",
        "viewport": {
          "width": 375,
          "height": 812
        },
        "deviceScaleFactor": 2,
        "isMobile": true,
        "hasTouch": true
      }
    }
  ]
}
